{
  "name": "@football-gm/engine",
  "version": "0.0.0",
  "private": true,
  "description": "Pure, deterministic, seeded football-league simulation core. No I/O, no framework, no DB. Runs in Node and the browser.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@football-gm/config": "workspace:*",
    "@types/node": "^22.10.2",
    "fast-check": "^3.23.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
