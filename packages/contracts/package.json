{
  "name": "@football-gm/contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Shared zod schemas + inferred DTO types. Single source of truth for the back/front API contract. Fleshed out in Phase 2.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@football-gm/config": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
