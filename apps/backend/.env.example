DATABASE_URL=postgresql://postgres:postgres@localhost:5544/football_gm
PORT=3000

# REQUERIDO: string aleatoria >= 32 chars.
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Correo y contraseña del admin inicial (cambiar en primer login).
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Resend API key para emails transaccionales.
# Dejar vacío para modo dry-run (logs en consola) en desarrollo local.
RESEND_API_KEY=

# URL del frontend — usada en links de emails y en el encabezado CORS.
APP_URL=http://localhost:5290
FRONTEND_ORIGIN=http://localhost:5290

NODE_ENV=development
